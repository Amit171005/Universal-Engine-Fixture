 <COLUMN ID=" 15">CNDP, Average Contact Depth</COLUMN>
 <COLUMN ID=" 16">PINB, Max. Resulting Pinball</COLUMN>
 <COLUMN ID=" 17">CAREA, Contacting Area</COLUMN>
 <COLUMN ID=" 18">PENE, Max. Penetration/Min. Gap</COLUMN>
 <COLUMN ID=" 19">CPLE, Max. Geometric Penetration</COLUMN>
 <COLUMN ID=" 20">CLGP, Max. Geometric Gap</COLUMN>
 <COLUMN ID=" 21">KNMX, Max. Normal Stiffness</COLUMN>
 <COLUMN ID=" 22">KNMN, Min. Normal Stiffness</COLUMN>
 <COLUMN ID=" 23">PRES, Max. Contact Pressure</COLUMN>
 <COLUMN ID=" 24">SFRI, Max. Friction Stress</COLUMN>
 <COLUMN ID=" 25">KTMX, Max. Tangential Stiffness</COLUMN>
 <COLUMN ID=" 26">KTMN, Min. Tangential Stiffness</COLUMN>
 <COLUMN ID=" 27">ESLI, Max. Elastic Slip Distance</COLUMN>
 <COLUMN ID=" 28">SLID, Max. Sliding Distance of Entire Solution</COLUMN>
 <COLUMN ID=" 29">GSMX, Max. Sliding Distance including near field</COLUMN>
