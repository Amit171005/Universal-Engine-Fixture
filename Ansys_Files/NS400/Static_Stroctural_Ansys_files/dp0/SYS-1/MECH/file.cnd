 <COLUMN ID=" 38">NORM, Contact pair force convergence norm</COLUMN>
 <COLUMN ID=" 39">CRIT, Contact pair force criterion</COLUMN>
 <COLUMN ID=" 40">NDMP, Max. Contact Damping Pressure</COLUMN>
 <COLUMN ID=" 41">TDMP, Max. Contact Damping Tangential stress</COLUMN>
 <COLUMN ID=" 42">CTEN, Total strain energy due to contact</COLUMN>
 <COLUMN ID=" 43">CFEN, Frictional dissipation energy</COLUMN>
 <COLUMN ID=" 44">CDEN, Contact damping dissipation energy</COLUMN>
